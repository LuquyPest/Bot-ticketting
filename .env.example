# Copie ce fichier en .env et remplis les valeurs avant de lancer docker compose.

# Mot de passe root MariaDB (usage interne Docker uniquement, jamais dans config.json)
# Utilise un mot de passe différent de DB_PASSWORD pour limiter les privilèges
DB_ROOT_PASSWORD=change_me_root

# Mot de passe de l'utilisateur 'botuser'
# Doit correspondre exactement à config.json → database.password
DB_PASSWORD=change_me_botuser
