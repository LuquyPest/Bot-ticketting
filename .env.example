# Mot de passe root MariaDB (usage interne Docker uniquement, pas dans config.json)
DB_ROOT_PASSWORD=root_changeme_fort

# Mot de passe de l'utilisateur 'botuser'
# Doit correspondre à config.json → database.password
DB_PASSWORD=changeme_fort

# Port exposé sur la machine hôte pour le dashboard web
# config.json → webServerPort doit rester à 3000 (port interne du conteneur)
WEB_PORT=3000
